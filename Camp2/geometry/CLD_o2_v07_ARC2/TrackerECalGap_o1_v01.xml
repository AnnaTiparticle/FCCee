            <section start="0*mm" end="TrackerECalGap_half_length"
                     rMin="TrackerECalGap_inner_radius" rMax="TrackerECalGap_outer_radius"
                     material="Plexiglass" name="TrackerECalGapCylinder" vis="SupportVis"/>
        </detector>
    </detectors>

</lccdd>
